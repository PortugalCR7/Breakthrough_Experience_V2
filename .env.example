# VITE_SUPABASE_URL: Your Supabase project's API URL.
# Find this in your Supabase dashboard under Project Settings > API.
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"

# VITE_SUPABASE_ANON_KEY: Your Supabase project's public anon/public key.
# Find this in your Supabase dashboard under Project Settings > API.
# Safe to expose in client-side code — it relies on Row Level Security
# (RLS) policies to restrict access, it is not a secret credential.
VITE_SUPABASE_ANON_KEY="your-anon-key-here"

# Do NOT add SUPABASE_SERVICE_ROLE_KEY here or to any hosting
# environment (e.g. Vercel). It bypasses RLS entirely and is only
# used for local admin/test scripts — never by the deployed app.